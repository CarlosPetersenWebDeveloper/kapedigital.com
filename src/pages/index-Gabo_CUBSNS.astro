---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Portfolio from '../components/Portfolio.astro';
import BlogPreview from '../components/BlogPreview.astro';
import TrustFAQ from '../components/TrustFAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

// FAQs del home (mismas que TrustFAQ usa) — se envían al Layout para generar FAQPage schema
// y obtener rich snippets de preguntas frecuentes en Google.
const faqs = [
  { question: '¿Qué necesito para empezar?', answer: 'Con tu idea, el nombre del negocio y una conversación breve alcanza para arrancar. Si ya tenés logo, textos o redes, mejor; si no, también podemos ordenarlo.' },
  { question: '¿Cuánto tarda un proyecto?', answer: 'Depende del alcance, pero la idea es trabajar por etapas y entregar rápido lo esencial para que tu negocio empiece a verse profesional cuanto antes.' },
  { question: '¿Puedo empezar con algo pequeño?', answer: 'Sí. De hecho, muchas PYMEs convierten mejor cuando empiezan con una base clara y luego escalan a un sitio más grande o una tienda.' },
  { question: '¿Ustedes me ayudan si solo tengo Instagram o WhatsApp?', answer: 'Sí. Justamente ahí es donde más sentido tiene ordenar la presencia digital y armar una base propia que no dependa solo de una red social.' },
];
---
<Layout
  title="Agencia de desarrollo web en Costa Rica — Kape Digital"
  description="Diseño y desarrollo web para PYMEs y emprendedores costarricenses. Sitios, tiendas en línea y presencia digital completa desde $250 + IVA. Cafecito exploratorio gratis."
  pageType="home"
  faqs={faqs}
>
  <Navbar />
  <main>
    <Hero />

    <!-- Value props bar -->
    <section class="bg-kape-beige py-10 border-y border-kape-medio/10">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          {[
            { icon: `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>`, label: 'Cafecito exploratorio gratis', sub: 'Sin compromiso · 30 min' },
            { icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,                            label: 'Entrega en plazos claros',    sub: 'Sin sorpresas ni excusas'   },
            { icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,                                             label: 'Sitios que cargan rápido',   sub: 'Optimizados para Google'    },
          ].map(v => (
            <div class="reveal flex flex-col items-center gap-2">
              <div class="w-10 h-10 bg-kape-white rounded-full flex items-center justify-center shadow-kape-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="#6F4E37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     set:html={v.icon}/>
              </div>
              <p class="font-jakarta font-semibold text-kape-oscuro text-sm">{v.label}</p>
              <p class="text-kape-medio/60 text-xs">{v.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Services />
    <Process />
    <TrustFAQ />
    <Portfolio />
    <BlogPreview />
    <CTA />
  </main>
  <Footer />
</Layout>
