---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

// Modelo WaaS: el cliente suscribe su presencia digital, no compra un sitio.
// Cada plan tiene dos momentos de pago: activación (construcción) + mensualidad (operación).
const packages = [
  {
    name: 'Grano', sub: 'Landing de conversión',
    activation: 'Desde $250', monthly: '$55/mes',
    priceNote: 'activación única',
    color: 'bg-amber-50', accent: '#D97706',
    desc: 'El primer paso para salir de Instagram. Una página bien hecha, diseñada para que el visitante tome acción.',
    includes: [
      'Diseño completamente personalizado',
      'Copywriting de la página',
      'Formulario de contacto',
      'Botón directo a WhatsApp',
      'Google Analytics 4 configurado',
      'Hosting + SSL activo (incluido en mensualidad)',
      'Soporte técnico por WhatsApp',
      'Monitoreo de uptime 24/7',
    ],
    ideal: 'Lanzar un producto o servicio · Reemplazar tu perfil de Instagram · Probar una idea de negocio',
  },
  {
    name: 'Tueste', sub: 'Paquete virtualización',
    activation: 'Desde $500', monthly: '$90/mes',
    priceNote: 'activación única',
    color: 'bg-kape-beige', accent: '#6F4E37',
    desc: 'La transformación digital completa para el negocio que opera por WhatsApp, redes o local físico y quiere dar el salto.',
    includes: [
      'Sitio web de 4 a 6 páginas',
      'Diseño responsivo (móvil + desktop)',
      'WhatsApp Business configurado',
      'Google Business Profile',
      'Correo profesional (vos@tunegocio.com)',
      'Google Analytics 4 + Search Console',
      'Capacitación completa de uso',
      'Hosting + SSL activo (incluido en mensualidad)',
      'Soporte técnico continuo',
    ],
    ideal: 'Negocios con producto o servicio probado · Tiendas físicas · Servicios profesionales',
    starred: true,
  },
  {
    name: 'Pergamino', sub: 'Tienda en línea',
    activation: 'Desde $800', monthly: '$140/mes',
    priceNote: 'activación única',
    color: 'bg-green-50', accent: '#15803D',
    desc: 'Todo lo del Tueste, más un catálogo de productos, pagos en línea y un panel que vos manejás.',
    includes: [
      'Todo el paquete Tueste',
      'Catálogo de productos filtrable',
      'Carrito de compras',
      'Pasarela de pago (SINPE, tarjeta)',
      'Panel de administración',
      'Gestión de inventario básica',
      'Confirmaciones por correo automáticas',
      'Backups diarios de la tienda',
      'Capacitación extendida',
    ],
    ideal: 'Negocios con productos físicos o digitales · Quienes venden por WhatsApp y quieren automatizar',
  },
  {
    name: 'Finca', sub: 'Sistema a medida',
    activation: 'Cotización', monthly: null,
    priceNote: 'según alcance',
    color: 'bg-orange-50', accent: '#EA580C',
    desc: 'Cuando la necesidad es única y no hay plantilla que la resuelva. Apps, portales, sistemas internos. Se cotiza por alcance, fuera del modelo de suscripción.',
    includes: [
      'Análisis de requerimientos',
      'Diseño de arquitectura',
      'Desarrollo a medida',
      'Integraciones con APIs externas',
      'Panel de administración personalizado',
      'Pruebas y QA',
      'Documentación técnica',
      'Soporte post-lanzamiento',
    ],
    ideal: 'Empresas con flujos específicos · Sistemas de gestión · Portales con login',
  },
];
---
<Layout title="Servicios — Kape Digital" description="Conocé los planes WaaS de Kape Digital: Grano, Tueste, Pergamino y Finca. Presencia digital operada desde $250 de activación + $55/mes.">
  <Navbar />
  <main class="pt-16">

    <!-- Page hero -->
    <section class="py-20 bg-kape-white relative overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
        <div class="coffee-ring coffee-ring-xl absolute -top-20 -right-24 opacity-25"></div>
      </div>
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center relative">
        <span class="section-pill">Servicios</span>
        <h1 class="font-jakarta font-extrabold text-4xl lg:text-5xl text-kape-oscuro mb-4">
          Elegí el tueste que necesitás
        </h1>
        <p class="accent-script text-xl text-kape-medio/80 max-w-xl mx-auto mb-6">
          Cada plan es una suscripción de presencia digital: vos pagás la activación una sola vez y nosotros la operamos mes a mes.
        </p>
        <p class="text-sm text-kape-medio/60">
          Permanencia mínima: 6 meses · Luego mes a mes con 15 días de aviso
        </p>
      </div>
    </section>

    <!-- Packages detail -->
    {packages.map((pkg, i) => (
      <section class={`py-16 ${i % 2 === 0 ? 'bg-kape-white' : 'bg-kape-beige'} relative overflow-hidden`}>
        <div class="max-w-5xl mx-auto px-6 lg:px-8">
          <div class={`grid lg:grid-cols-2 gap-12 items-start ${i % 2 === 1 ? 'lg:grid-flow-col-dense' : ''}`}>

            <!-- Left: info -->
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="font-jakarta font-extrabold text-sm uppercase tracking-widest"
                      style={`color: ${pkg.accent}`}>{pkg.name}</span>
                {pkg.starred && (
                  <span class="bg-kape-naranja text-white text-xs font-bold px-3 py-1 rounded-full">
                    ⭐ Más solicitado
                  </span>
                )}
              </div>
              <h2 class="font-jakarta font-extrabold text-3xl lg:text-4xl text-kape-oscuro mb-2">
                {pkg.sub}
              </h2>
              <div class="mb-6">
                <p class="font-jakarta font-extrabold text-3xl" style={`color: ${pkg.accent}`}>
                  {pkg.activation}
                  <span class="text-base font-normal text-kape-medio/60 ml-2">· {pkg.priceNote}</span>
                </p>
                {pkg.monthly && (
                  <p class="font-jakarta font-semibold text-xl text-kape-medio mt-1">
                    + {pkg.monthly} <span class="text-sm font-normal text-kape-medio/60">(operación continua)</span>
                  </p>
                )}
              </div>
              <p class="text-kape-medio/80 text-base leading-relaxed mb-6">{pkg.desc}</p>

              <div class="bg-kape-beige/60 rounded-xl p-4 text-sm text-kape-medio/70 mb-8">
                <p class="font-semibold text-kape-oscuro text-xs uppercase tracking-wider mb-2">Ideal para:</p>
                {pkg.ideal}
              </div>

              <a href="#cafecito"
                 class="inline-flex items-center gap-2 bg-kape-naranja text-white font-bold px-7 py-3.5 rounded-full btn-ripple hover:bg-orange-700 transition-colors">
                Agendar cafecito gratis →
              </a>
            </div>

            <!-- Right: includes -->
            <div class={`${pkg.color} rounded-2xl p-7`}>
              <p class="font-jakarta font-bold text-kape-oscuro text-sm uppercase tracking-wider mb-5">
                Incluye:
              </p>
              <ul class="space-y-3">
                {pkg.includes.map(item => (
                  <li class="flex items-start gap-3 text-sm text-kape-medio/80">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke={pkg.accent} stroke-width="2.5" stroke-linecap="round"
                         stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Catación express -->
    <section class="py-12 bg-kape-white">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 flex flex-col md:flex-row items-start md:items-center gap-6">
          <div class="flex-1">
            <span class="font-jakarta font-extrabold text-xs uppercase tracking-widest text-amber-600 mb-1 block">Diagnóstico</span>
            <h3 class="font-jakarta font-extrabold text-2xl text-kape-oscuro mb-2">Catación express</h3>
            <p class="text-kape-medio/75 text-sm leading-relaxed">
              Revisamos tu estado digital actual y te entregamos un reporte con hallazgos y recomendaciones concretas. No requiere suscripción. Es el mejor punto de partida si ya tenés algo en internet y querés saber qué está fallando.
            </p>
          </div>
          <div class="text-center md:text-right flex-shrink-0">
            <p class="font-jakarta font-extrabold text-3xl text-amber-600">$90</p>
            <p class="text-xs text-kape-medio/60 mb-4">pago único · cotización independiente</p>
            <a href="#cafecito" class="inline-flex items-center gap-2 bg-kape-naranja text-white font-bold px-6 py-3 rounded-full btn-ripple hover:bg-orange-700 transition-colors text-sm">
              Agendar cafecito →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Mantenimiento externo (Sobremesa) -->
    <section class="py-16 bg-kape-beige">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="section-pill">Sobremesa</span>
        <h2 class="font-jakarta font-extrabold text-3xl text-kape-oscuro mb-2">
          Mantenimiento para sitios externos
        </h2>
        <p class="text-kape-medio/70 text-sm mb-8 max-w-xl mx-auto">
          ¿Tenés un sitio web que no construimos nosotros y querés que lo operemos? Este plan es para vos. El soporte técnico de los planes Grano, Tueste y Pergamino ya está incluido en su mensualidad.
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          {[
            { plan: 'Plan Básico', price: '$120/mes', items: ['Actualizaciones de seguridad', 'Respaldo mensual', 'Reporte de métricas', 'Soporte por WhatsApp'] },
            { plan: 'Plan Completo', price: '$220/mes', items: ['Todo el plan básico', 'Mejoras y ajustes continuos', 'Reunión sobremesa mensual', 'Prioridad en respuesta'] },
          ].map(m => (
            <div class="bg-kape-white rounded-2xl p-7 text-left">
              <h3 class="font-jakarta font-bold text-kape-oscuro text-xl mb-1">{m.plan}</h3>
              <p class="font-jakarta font-extrabold text-kape-medio text-2xl mb-5">{m.price}</p>
              <ul class="space-y-2">
                {m.items.map(it => (
                  <li class="flex items-center gap-2 text-sm text-kape-medio/75">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="#15803D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {it}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
