---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Process from '../../components/Process.astro';
import Portfolio from '../../components/Portfolio.astro';
import BlogPreview from '../../components/BlogPreview.astro';
import TrustFAQ from '../../components/TrustFAQ.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const faqs = [
  { question: 'What do I need to get started?', answer: 'Your idea, the business name, and a short conversation are enough to begin. If you already have a logo, copy, or social channels, great; if not, we can organize that too.' },
  { question: 'How long does a project take?', answer: 'It depends on scope, but the idea is to work in stages and deliver the essentials quickly so your business starts looking professional sooner.' },
  { question: 'Can I start with something small?', answer: 'Yes. In fact, many SMEs convert better when they start with a clear base and later scale up to a larger site or store.' },
  { question: 'Can you help if I only have Instagram or WhatsApp?', answer: 'Yes. That is exactly where it makes the most sense to organize the digital presence and build an owned base that does not depend on one social network.' },
];
---
<Layout
  locale="en"
  title="Web Development Agency in Costa Rica — Kape Digital"
  description="Web design and development for Costa Rican SMEs and entrepreneurs. Custom websites, online stores, and complete digital presence from $250 + VAT. Free discovery coffee chat."
  pageType="home"
  faqs={faqs}
>
  <Navbar />
  <main>
    <Hero />

    <section class="bg-kape-beige py-10 border-y border-kape-medio/10">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          {[
            { icon: `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>`, label: 'Free discovery coffee', sub: 'No commitment · 30 min' },
            { icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`, label: 'Clear delivery timelines', sub: 'No surprises or excuses' },
            { icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`, label: 'Fast-loading sites', sub: 'Optimized for Google' },
          ].map((v) => (
            <div class="reveal flex flex-col items-center gap-2">
              <div class="w-10 h-10 bg-kape-white rounded-full flex items-center justify-center shadow-kape-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6F4E37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={v.icon} />
              </div>
              <p class="font-jakarta font-semibold text-kape-oscuro text-sm">{v.label}</p>
              <p class="text-kape-medio/60 text-xs">{v.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Services />
    <Process />
    <TrustFAQ />
    <Portfolio />
    <BlogPreview />
    <CTA />
  </main>
  <Footer />
</Layout>
