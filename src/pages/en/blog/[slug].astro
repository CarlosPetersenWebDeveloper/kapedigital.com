---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getBlogPosts } from '../../../data/blog';

export function getStaticPaths() {
  return getBlogPosts('en').map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
---
<Layout locale="en" title={`${post.title} · Kape Digital`} description={post.description}>
  <Navbar />
  <main class="pt-16">
    <article class="py-16 bg-kape-beige">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <a href="/en/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-kape-naranja hover:underline mb-8">← Back to blog</a>
        <div class="bg-kape-white rounded-3xl p-5 mb-8 border border-kape-beige/80 text-kape-medio/75 text-sm leading-relaxed">This article body is currently available in Spanish. The bilingual site structure is ready, and the article archive can be translated next without changing the route structure.</div>
        <header class="bg-kape-white rounded-3xl shadow-[0_8px_40px_rgba(111,78,55,0.10)] p-8 lg:p-10 mb-8"><div class="flex flex-wrap items-center gap-3 mb-4"><span class="section-pill">{post.category}</span><span class="text-sm text-kape-medio/60">{post.date} · {post.readTime} read</span></div><h1 class="font-jakarta font-extrabold text-3xl lg:text-5xl text-kape-oscuro leading-tight mb-4">{post.title}</h1><p class="text-lg text-kape-medio/75 max-w-2xl leading-relaxed">{post.excerpt}</p></header>
        <div class={`h-2 ${post.accent.replace('border-', 'bg-')} rounded-full mb-8`}></div>
        <div class="space-y-6">{post.sections.map((section) => <section class="bg-kape-white rounded-3xl p-8 shadow-[0_8px_30px_rgba(111,78,55,0.06)]"><h2 class="font-jakarta font-bold text-2xl text-kape-oscuro mb-4">{section.heading}</h2><div class="space-y-4 text-kape-medio/80 leading-relaxed">{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}</div>{section.bullets && <ul class="mt-5 space-y-2 text-kape-medio/80">{section.bullets.map((bullet) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-kape-naranja flex-shrink-0"></span><span>{bullet}</span></li>)}</ul>}</section>)}</div>
        <footer class="mt-10 bg-kape-oscuro rounded-3xl p-8 text-kape-beige"><p class="text-sm uppercase tracking-[0.2em] text-kape-beige/60 mb-3">Next step</p><p class="text-xl font-jakarta font-semibold mb-5">If you want to apply this to your business, we can map it out together in a short call.</p><a href="/en/#cafecito" class="inline-flex items-center justify-center rounded-full bg-kape-naranja px-6 py-3 font-semibold text-white hover:bg-orange-500 transition-colors">Book a coffee chat</a></footer>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
