---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  { slug: 'por-que-tu-negocio-no-aparece-en-google', category: 'SEO', title: '¿Por qué tu negocio no aparece en Google?', excerpt: 'La respuesta no es "hacé SEO". Es más sencillo y más profundo que eso. Acá te explico por dónde empezar sin gastar un colón.', readTime: '5 min', date: 'Abril 2026', accent: 'border-amber-400' },
  { slug: 'whatsapp-business-lo-basico', category: 'Digitalización', title: 'WhatsApp Business: lo básico que todo negocio necesita', excerpt: 'Catálogo de productos, respuestas automáticas y un perfil profesional. Todo gratis. Te enseño a configurarlo en 20 minutos.', readTime: '4 min', date: 'Abril 2026', accent: 'border-green-500' },
  { slug: 'landing-page-vs-sitio-web', category: 'Web', title: 'Landing page vs sitio web: ¿cuál necesitás primero?', excerpt: 'Depende de en qué etapa está tu negocio. Te ayudo a entender la diferencia con ejemplos reales de Costa Rica.', readTime: '6 min', date: 'Marzo 2026', accent: 'border-kape-naranja' },
  { slug: 'cuanto-cuesta-un-sitio-web-costa-rica', category: 'Costos', title: '¿Cuánto cuesta tener un sitio web en Costa Rica?', excerpt: 'Entre $200 y $20,000. El rango es enorme y la diferencia importa. Te explico qué está detrás de cada precio.', readTime: '5 min', date: 'Marzo 2026', accent: 'border-kape-naranja' },
  { slug: 'instagram-no-es-un-sitio-web', category: 'Estrategia', title: 'Instagram no es un sitio web: diferencias que importan', excerpt: 'Miles de emprendedores usan Instagram como su única presencia digital. Esto es lo que están arriesgando.', readTime: '4 min', date: 'Febrero 2026', accent: 'border-purple-500' },
];
---
<Layout title="Blog — Notas de tueste · Kape Digital" description="Artículos prácticos sobre digitalización, sitios web y marketing para negocios costarricenses.">
  <Navbar />
  <main class="pt-16">

    <!-- Hero -->
    <section class="py-20 bg-kape-white relative overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
        <div class="coffee-ring coffee-ring-xl absolute -top-12 -left-16 opacity-20"></div>
      </div>
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center relative">
        <span class="section-pill">Blog</span>
        <h1 class="font-jakarta font-extrabold text-4xl lg:text-5xl text-kape-oscuro mb-4">
          Notas de tueste
        </h1>
        <p class="accent-script text-xl text-kape-medio/80 max-w-xl mx-auto">
          Artículos prácticos para digitalizar tu negocio costarricense.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="py-12 bg-kape-beige pb-24">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">

        <!-- Featured post -->
        <article class="reveal bg-kape-white rounded-2xl overflow-hidden shadow-[0_8px_40px_rgba(111,78,55,0.10)] mb-8 group hover:-translate-y-1 transition-transform duration-300">
          <div class={`h-2 ${posts[0].accent.replace('border-', 'bg-')}`}></div>
          <div class="p-8 grid md:grid-cols-2 gap-6 items-center">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold uppercase tracking-wider text-kape-naranja">{posts[0].category}</span>
                <span class="text-xs text-kape-medio/50">{posts[0].date} · {posts[0].readTime} de lectura</span>
              </div>
              <h2 class="font-jakarta font-extrabold text-2xl text-kape-oscuro mb-3 group-hover:text-kape-medio transition-colors">
                {posts[0].title}
              </h2>
              <p class="text-kape-medio/75 text-sm leading-relaxed mb-5">{posts[0].excerpt}</p>
              <a href={`/blog/${posts[0].slug}`}
                 class="inline-flex items-center gap-1.5 text-kape-naranja font-semibold text-sm hover:gap-3 transition-all">
                Leer nota →
              </a>
            </div>
            <div class="bg-kape-beige rounded-xl h-44 flex items-center justify-center">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F4E37" stroke-width="1.5" stroke-linecap="round" opacity="0.4">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
          </div>
        </article>

        <!-- Rest of posts -->
        <div class="grid md:grid-cols-2 gap-5">
          {posts.slice(1).map((post, i) => (
            <article class={`reveal reveal-delay-${i + 1} bg-kape-white rounded-2xl overflow-hidden border-l-4 ${post.accent}
                             hover:shadow-[0_8px_32px_rgba(111,78,55,0.12)] hover:-translate-y-1 transition-all duration-300 group`}>
              <div class="p-6">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-bold uppercase tracking-wider text-kape-naranja">{post.category}</span>
                  <span class="text-xs text-kape-medio/50">{post.readTime} de lectura</span>
                </div>
                <h2 class="font-jakarta font-bold text-kape-oscuro text-lg mb-2 group-hover:text-kape-medio transition-colors leading-snug">
                  {post.title}
                </h2>
                <p class="text-kape-medio/70 text-sm leading-relaxed mb-4">{post.excerpt}</p>
                <a href={`/blog/${post.slug}`}
                   class="inline-flex items-center gap-1.5 text-kape-naranja text-sm font-semibold hover:gap-3 transition-all">
                  Leer nota →
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- Newsletter signup -->
        <div class="reveal mt-12 bg-kape-oscuro rounded-2xl p-8 text-center">
          <p class="text-kape-beige/60 text-sm mb-2">Una vez al mes, sin spam</p>
          <h3 class="font-jakarta font-bold text-white text-2xl mb-4">
            Suscribite a la <span class="text-kape-naranja">Bolsa mensual</span>
          </h3>
          <p class="text-kape-beige/70 text-sm mb-6 max-w-sm mx-auto">
            Lo más relevante sobre digitalización para negocios ticos, en un solo correo.
          </p>
          <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input type="email" placeholder="tu@correo.com"
                   class="flex-1 bg-kape-white/10 border border-kape-beige/20 text-white placeholder-kape-beige/40
                          rounded-xl px-4 py-3 text-sm outline-none focus:border-kape-naranja transition-colors"/>
            <button type="submit"
                    class="bg-kape-naranja text-white font-semibold px-6 py-3 rounded-xl hover:bg-orange-500 transition-colors btn-ripple">
              Suscribirme
            </button>
          </form>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>
