---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    name: 'MVP Cards CR', url: 'https://mvpcardscr.com',
    type: 'Pergamino · Tienda en línea',
    desc: 'Tienda de artículos coleccionables con catálogo filtrable por tipo de producto carrito de compras y pagos en línea. Diseñada para coleccionistas costarricenses.',
    challenge: 'El cliente vendía solo por Instagram DM y WhatsApp, perdiendo ventas por falta de disponibilidad 24/7.',
    result: 'Tienda activa con pedidos automatizados y catálogo actualizable sin ayuda técnica.',
    tags: ['React', 'PHP', 'MySQL', 'Cloudflare'],
    color: 'from-amber-100 to-amber-50',
  },
  {
    name: 'BeeStore CR', url: 'https://beestorecr.com',
    type: 'Pergamino · Tienda en línea',
    desc: 'E-commerce de cosméticos y cuidado personal costarricense, sin pasarela de pago, con panel de gestión de inventario.',
    challenge: 'Negocio con buen producto pero sin presencia digital. Las ventas dependían 100% de ferias y boca a boca.',
    result: 'Canal de ventas digital activo, con clientes de todo el país encontrando el negocio en Google.',
    tags: ['PHP', 'MySQL', 'React', 'DigitalOcean'],
    color: 'from-green-100 to-green-50',
  },
  {
    name: 'AJ Soluciones SA', url: 'https://ajsolucionessacr.com',
    type: 'Tueste · Virtualización',
    desc: 'Sitio informativo sobre el negocio de la venta de reactivos, desarrollado con PHP y WordPress para presentar la empresa y sus servicios.',
    challenge: 'Empresa de servicios con clientes activos pero sin presencia web. Los clientes no podían encontrarlos en Google.',
    result: 'Aparecen en Google Maps, tienen correo corporativo y un sitio que genera primeras impresiones sólidas.',
    tags: ['PHP', 'WordPress', 'MySQL', 'Cloudflare'],
    color: 'from-blue-100 to-blue-50',
  },
];
---
<Layout title="Portafolio — Kape Digital" description="Proyectos de desarrollo web de Kape Digital: tiendas en línea, sitios corporativos y más.">
  <Navbar />
  <main class="pt-16">

    <!-- Hero -->
    <section class="py-20 bg-kape-white relative overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
        <div class="coffee-ring coffee-ring-lg absolute top-8 left-8 opacity-20"></div>
        <div class="coffee-ring coffee-ring-xl absolute -bottom-16 -right-16 opacity-15"></div>
      </div>
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center relative">
        <span class="section-pill">Portafolio</span>
        <h1 class="font-jakarta font-extrabold text-4xl lg:text-5xl text-kape-oscuro mb-4">
          Proyectos recientes
        </h1>
        <p class="accent-script text-xl text-kape-medio/80 max-w-xl mx-auto">
          Cada sitio es un negocio real que decidió dar el salto digital.
        </p>
      </div>
    </section>

    <!-- Projects -->
    {projects.map((p, i) => (
      <section class={`py-16 ${i % 2 === 0 ? 'bg-kape-beige' : 'bg-kape-white'}`}>
        <div class="max-w-5xl mx-auto px-6 lg:px-8">
          <div class={`grid lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:grid-flow-col-dense' : ''}`}>

            <!-- Browser mockup -->
            <div class={`reveal ${i % 2 === 1 ? 'reveal-right lg:col-start-2' : 'reveal-left'}`}>
              <div class={`rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(111,78,55,0.15)] bg-gradient-to-br ${p.color}`}>
                <!-- Browser chrome -->
                <div class="bg-kape-beige px-4 py-3 flex items-center gap-2.5">
                  <span class="w-3 h-3 rounded-full bg-red-400"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                  <span class="w-3 h-3 rounded-full bg-green-400"></span>
                  <div class="flex-1 bg-kape-white rounded-full px-3 py-1 text-xs text-kape-medio/50">
                    {p.url}
                  </div>
                </div>
                <!-- Content placeholder -->
                <div class="p-6 space-y-3">
                  <div class="h-5 w-1/2 bg-kape-medio/15 rounded-lg"></div>
                  <div class="h-3 w-full bg-kape-medio/10 rounded"></div>
                  <div class="h-3 w-4/5 bg-kape-medio/10 rounded"></div>
                  <div class="grid grid-cols-3 gap-3 mt-4">
                    {[1,2,3].map(() => <div class="aspect-square bg-kape-medio/10 rounded-xl"></div>)}
                  </div>
                  <div class="h-3 w-3/5 bg-kape-medio/10 rounded mt-2"></div>
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class={`reveal ${i % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
              <p class="text-xs font-bold uppercase tracking-widest text-kape-naranja mb-2">{p.type}</p>
              <h2 class="font-jakarta font-extrabold text-3xl text-kape-oscuro mb-4">{p.name}</h2>
              <p class="text-kape-medio/80 text-base leading-relaxed mb-6">{p.desc}</p>

              <div class="space-y-4 mb-6">
                <div class="bg-kape-beige/60 rounded-xl p-4">
                  <p class="text-xs font-bold text-kape-medio/50 uppercase tracking-wider mb-1">El reto</p>
                  <p class="text-sm text-kape-medio/80">{p.challenge}</p>
                </div>
                <div class="bg-green-50 rounded-xl p-4">
                  <p class="text-xs font-bold text-green-700/60 uppercase tracking-wider mb-1">El resultado</p>
                  <p class="text-sm text-kape-medio/80">{p.result}</p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mb-6">
                {p.tags.map(t => (
                  <span class="bg-kape-beige text-kape-medio text-xs px-3 py-1.5 rounded-full font-medium">{t}</span>
                ))}
              </div>

              <a href={p.url} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-2 text-kape-naranja font-semibold text-sm hover:underline">
                Ver sitio en vivo
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 0 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>
    ))}

    <CTA />
  </main>
  <Footer />
</Layout>
