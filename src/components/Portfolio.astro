---
import { getLocale, getSiteText } from '../i18n';

const locale = getLocale(Astro.url.pathname);
const text = getSiteText(locale);
const projects = locale === 'en'
  ? [
      { name: 'MVP Cards CR', url: 'https://mvpcardscr.com', type: 'Pergamino · Online store', desc: 'A collectibles store with a filterable catalog, cart, and online payments.', tags: ['React', 'PHP', 'MySQL', 'Cloudflare'], color: 'from-amber-900/20 to-amber-700/10' },
      { name: 'BeeStore CR', url: 'https://beestorecr.com', type: 'Pergamino · Online store', desc: 'A Costa Rican cosmetics and personal care e-commerce site, without a payment gateway, with inventory management.', tags: ['PHP', 'MySQL', 'React', 'DigitalOcean'], color: 'from-yellow-700/20 to-yellow-500/10' },
      { name: 'AJ Soluciones SA', url: 'https://ajsolucionessacr.com', type: 'Tueste · Digitalization', desc: 'An informational site about reagent sales, built with PHP and WordPress to present the business and services clearly.', tags: ['PHP', 'WordPress', 'MySQL', 'Cloudflare'], color: 'from-kape-medio/15 to-kape-beige/30' },
    ]
  : [
      { name: 'MVP Cards CR', url: 'https://mvpcardscr.com', type: 'Pergamino · Tienda en línea', desc: 'Tienda de tarjetas artículos coleccionables con catálogo filtrable, carrito y pagos en línea.', tags: ['React', 'PHP', 'MySQL', 'Cloudflare'], color: 'from-amber-900/20 to-amber-700/10' },
      { name: 'BeeStore CR', url: 'https://beestorecr.com', type: 'Pergamino · Tienda en línea', desc: 'E-commerce de cosméticos y cuidado personal costarricense, sin pasarela de pago, con panel de gestión de inventario.', tags: ['PHP', 'MySQL', 'React', 'DigitalOcean'], color: 'from-yellow-700/20 to-yellow-500/10' },
      { name: 'AJ Soluciones SA', url: 'https://ajsolucionessacr.com', type: 'Tueste · Virtualización', desc: 'Sitio informativo sobre la venta de reactivos, desarrollado con PHP y WordPress para presentar el negocio y sus servicios de forma clara.', tags: ['PHP', 'WordPress', 'MySQL', 'Cloudflare'], color: 'from-kape-medio/15 to-kape-beige/30' },
    ];
---
<section id="portafolio" class="py-24 bg-kape-beige relative overflow-hidden">

  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
      <div>
        <div class="reveal inline-flex items-center gap-2 bg-kape-white text-kape-medio text-xs font-medium px-4 py-1.5 rounded-full mb-4">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          {text.portfolioSection.eyebrow}
        </div>
        <h2 class="reveal reveal-delay-1 font-jakarta font-bold text-3xl lg:text-4xl text-kape-oscuro">
          {text.portfolioSection.title}
        </h2>
      </div>
      <p class="reveal reveal-delay-2 text-kape-medio/80 text-base max-w-sm">
        {text.portfolioSection.subtitle}
      </p>
    </div>

    <!-- Projects -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p, i) => (
        <article class={`reveal reveal-delay-${i + 1} group bg-kape-white rounded-2xl overflow-hidden shadow-kape-sm hover:shadow-kape-lg transition-all duration-400`}>

          <!-- Screenshot placeholder with gradient -->
          <div class={`relative h-44 bg-gradient-to-br ${p.color} flex items-center justify-center overflow-hidden`}>
            <!-- Browser chrome mockup -->
            <div class="absolute inset-3 bg-white/80 rounded-xl shadow-sm overflow-hidden">
              <!-- Browser bar -->
              <div class="h-7 bg-kape-beige flex items-center px-3 gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
                <span class="ml-2 flex-1 h-3.5 bg-kape-white rounded-full text-[8px] text-kape-medio/50 flex items-center px-2">
                  {p.url}
                </span>
              </div>
              <!-- Content area -->
              <div class="p-3 space-y-2">
                <div class="h-4 w-2/3 bg-kape-beige rounded"></div>
                <div class="h-3 w-full bg-kape-beige/60 rounded"></div>
                <div class="h-3 w-4/5 bg-kape-beige/60 rounded"></div>
                <div class="grid grid-cols-3 gap-2 mt-3">
                  {[1,2,3].map(_ => (
                    <div class="h-10 bg-kape-beige/50 rounded-lg"></div>
                  ))}
                </div>
              </div>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-kape-oscuro/0 group-hover:bg-kape-oscuro/20 transition-colors duration-300 flex items-center justify-center">
              <a href={p.url} target="_blank" rel="noopener"
                 class="opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0
                        bg-white text-kape-oscuro text-xs font-semibold px-4 py-2 rounded-full flex items-center gap-1.5">
                {text.portfolioSection.liveSite}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 0 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Content -->
          <div class="p-5">
            <p class="text-xs text-kape-naranja font-medium uppercase tracking-wider mb-1">{p.type}</p>
            <h3 class="font-jakarta font-bold text-kape-oscuro text-lg mb-2">{p.name}</h3>
            <p class="text-kape-medio/70 text-sm leading-relaxed mb-4">{p.desc}</p>
            <!-- Tech tags -->
            <div class="flex flex-wrap gap-2">
              {p.tags.map(tag => (
                <span class="bg-kape-beige text-kape-medio text-xs px-2.5 py-1 rounded-full font-medium">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
