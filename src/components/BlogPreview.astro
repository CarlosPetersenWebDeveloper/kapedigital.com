---
import { getBlogPosts } from '../data/blog';
import { getLocale, getSiteText, localizedPath } from '../i18n';

const locale = getLocale(Astro.url.pathname);
const text = getSiteText(locale);
const blogPosts = getBlogPosts(locale);
---
<section id="blog" class="py-24 bg-kape-beige">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
      <div>
        <div class="reveal inline-flex items-center gap-2 bg-kape-white text-kape-medio text-xs font-medium px-4 py-1.5 rounded-full mb-4">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          {text.blogPreview.eyebrow}
        </div>
        <h2 class="reveal reveal-delay-1 font-jakarta font-bold text-3xl lg:text-4xl text-kape-oscuro">
          {text.blogPreview.title}
        </h2>
      </div>
      <a href={localizedPath(Astro.url.pathname, '/blog')}
         class="reveal reveal-delay-2 inline-flex items-center gap-2 text-kape-naranja font-semibold text-sm hover:underline whitespace-nowrap">
        {text.blogPreview.cta}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <!-- Posts -->
    <div class="grid md:grid-cols-3 gap-6">
      {blogPosts.slice(0, 3).map((post, i) => (
        <article class={`reveal reveal-delay-${i + 1} ${post.color} rounded-2xl overflow-hidden
                         hover:shadow-kape-md transition-all duration-300 hover:-translate-y-1 group`}>
          <!-- Color bar top -->
          <div class={`h-1.5 ${post.accent}`}></div>
          <div class="p-6">
            <!-- Category + read time -->
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-semibold text-kape-medio/70 uppercase tracking-wider">
                {post.category}
              </span>
              <span class="text-xs text-kape-medio/50 flex items-center gap-1">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {post.readTime} {locale === 'en' ? 'read' : 'de lectura'}
              </span>
            </div>

            <!-- Title -->
            <h3 class="font-jakarta font-bold text-kape-oscuro text-lg leading-snug mb-3 group-hover:text-kape-medio transition-colors">
              {post.title}
            </h3>

            <!-- Excerpt -->
            <p class="text-kape-medio/70 text-sm leading-relaxed mb-5">
              {post.excerpt}
            </p>

            <!-- Read link -->
            <a href={localizedPath(Astro.url.pathname, `/blog/${post.slug}`)}
               class="inline-flex items-center gap-1.5 text-kape-naranja text-sm font-semibold hover:gap-2.5 transition-all">
              {text.blogPreview.read}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
