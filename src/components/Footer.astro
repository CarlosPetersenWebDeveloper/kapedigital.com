---
import { getLocale, getSiteText, localizedPath } from '../i18n';

const year = new Date().getFullYear();
const locale = getLocale(Astro.url.pathname);
const text = getSiteText(locale);
const links = {
  servicios: [
    locale === 'en'
      ? { label: 'Grano — Landing page',          href: localizedPath(Astro.url.pathname, '/servicios') }
      : { label: 'Grano — Landing',                href: localizedPath(Astro.url.pathname, '/servicios') },
    locale === 'en'
      ? { label: 'Tueste — Digitalization',        href: localizedPath(Astro.url.pathname, '/servicios') }
      : { label: 'Tueste — Virtualización',        href: localizedPath(Astro.url.pathname, '/servicios') },
    locale === 'en'
      ? { label: 'Pergamino — Online store',       href: localizedPath(Astro.url.pathname, '/servicios') }
      : { label: 'Pergamino — Tienda',             href: localizedPath(Astro.url.pathname, '/servicios') },
    locale === 'en'
      ? { label: 'Finca — Custom system',          href: localizedPath(Astro.url.pathname, '/servicios') }
      : { label: 'Finca — A medida',               href: localizedPath(Astro.url.pathname, '/servicios') },
    locale === 'en'
      ? { label: 'After-dinner chat — Maintenance', href: localizedPath(Astro.url.pathname, '/servicios') }
      : { label: 'Sobremesa — Mantenimiento',      href: localizedPath(Astro.url.pathname, '/servicios') },
  ],
  empresa: [
    { label: locale === 'en' ? 'About' : 'Sobre mí', href: localizedPath(Astro.url.pathname, '/sobre') },
    { label: text.nav.portfolio, href: localizedPath(Astro.url.pathname, '/portafolio') },
    { label: locale === 'en' ? 'Roast notes' : 'Notas de tueste', href: localizedPath(Astro.url.pathname, '/blog') },
    { label: locale === 'en' ? 'Privacy policy' : 'Política de privacidad', href: localizedPath(Astro.url.pathname, '/privacidad') },
  ],
};
---
<footer class="bg-kape-oscuro text-kape-beige">

  <!-- Main footer content -->
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <div class="flex items-center gap-2.5 mb-4">
          <svg width="30" height="30" viewBox="0 0 32 32" fill="none">
            <path d="M5 14 L6 26 Q10 30 16 30 Q22 30 26 26 L27 14 Z" fill="#F5E9DA" fill-opacity="0.15" stroke="#F5E9DA" stroke-width="1"/>
            <ellipse cx="16" cy="14" rx="11" ry="3.5" fill="#4B2E2B"/>
            <ellipse cx="16" cy="14.5" rx="10" ry="2.8" fill="#6F4E37"/>
            <path d="M27 18 Q32 18 32 22 Q32 26 27 26" stroke="#F5E9DA" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-opacity="0.5"/>
          </svg>
          <span class="font-jakarta font-bold text-xl">
            <span class="text-kape-naranja">K</span><span class="text-kape-white">ape</span>
            <span class="text-kape-beige/60 font-normal italic text-sm ml-1">Digital</span>
          </span>
        </div>

        <p class="text-kape-beige/60 text-sm leading-relaxed mb-6 max-w-xs">
          {text.footer.intro}
        </p>

        <!-- Contact -->
        <div class="space-y-2 text-sm text-kape-beige/60">
          <a href="mailto:hola@kapedigital.com"
             class="flex items-center gap-2 hover:text-kape-beige transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            hola@kapedigital.com
          </a>
          <a href="https://kapedigital.com"
             class="flex items-center gap-2 hover:text-kape-beige transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            kapedigital.com
          </a>
          <p class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Costa Rica
          </p>
        </div>
      </div>

      <!-- Servicios -->
      <div>
        <h3 class="font-jakarta font-semibold text-kape-white text-sm uppercase tracking-wider mb-5">
          {text.footer.services}
        </h3>
        <ul class="space-y-3">
          {links.servicios.map(l => (
            <li>
              <a href={l.href}
                 class="text-kape-beige/60 text-sm hover:text-kape-beige transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h3 class="font-jakarta font-semibold text-kape-white text-sm uppercase tracking-wider mb-5">
          {text.footer.company}
        </h3>
        <ul class="space-y-3">
          {links.empresa.map(l => (
            <li>
              <a href={l.href}
                 class="text-kape-beige/60 text-sm hover:text-kape-beige transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- CTA mini -->
        <div class="mt-8">
          <a
            href="#cafecito"
            class="inline-flex items-center gap-2 bg-kape-naranja text-white text-xs font-semibold
                   px-4 py-2.5 rounded-full hover:bg-orange-500 transition-colors"
          >
            {text.footer.cta} →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-kape-beige/10">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-kape-beige/40 text-xs">
        © {year} Kape Digital · {text.footer.copyright} · Costa Rica
      </p>
      <p class="text-kape-beige/30 text-xs">
        {text.footer.handmade}
      </p>
    </div>
  </div>
</footer>
