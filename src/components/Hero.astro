---
import { getLocale, getSiteText, localizedPath } from '../i18n';

const locale = getLocale(Astro.url.pathname);
const text = getSiteText(locale);
---
<section class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-kape-white pt-16">

  <!-- Canvas: falling coffee beans -->
  <canvas id="beans-canvas" aria-hidden="true"></canvas>

  <!-- Coffee ring decorations (background ornaments) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none select-none overflow-hidden">
    <div class="coffee-ring coffee-ring-xl absolute -top-24 -right-32 opacity-40"></div>
    <div class="coffee-ring coffee-ring-lg absolute bottom-16 -left-20 opacity-30"></div>
    <div class="coffee-ring coffee-ring-md absolute top-1/3 right-[12%] opacity-20"></div>
    <div class="coffee-ring coffee-ring-sm absolute bottom-1/4 left-[20%] opacity-25"></div>
  </div>

  <!-- Main content -->
  <div class="relative max-w-5xl mx-auto px-6 lg:px-8 py-20 lg:py-28 text-center">

    <!-- Brand label -->
    <div class="reveal flex justify-center mb-8">
      <span class="section-pill">
        <span class="w-1.5 h-1.5 rounded-full bg-kape-naranja inline-block"></span>
        {text.hero.eyebrow}
      </span>
    </div>

    <!-- Main headline -->
    <h1 class="reveal reveal-delay-1 font-jakarta font-extrabold leading-[1.1] text-kape-oscuro mb-6"
        style="font-size: clamp(2.4rem, 6vw, 5rem);">
      {text.hero.titleTop}<span class="text-kape-medio">,</span>
      <br />
      <em class="accent-script font-normal not-italic"
          style="font-size: clamp(2rem, 5vw, 4.2rem); color: #6F4E37;">
        {text.hero.titleAccent}
      </em>
    </h1>

    <!-- Slogan -->
    <p class="reveal reveal-delay-2 text-kape-medio/70 text-lg lg:text-xl leading-relaxed mb-10 max-w-2xl mx-auto">
      {text.hero.description}
    </p>

    <!-- CTAs -->
    <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center mb-14">
      <a href="#cafecito"
         class="btn-ripple inline-flex items-center justify-center gap-2.5 bg-kape-naranja text-white
                font-jakarta font-bold text-base px-8 py-4 rounded-full
                hover:bg-orange-700 transition-colors duration-300 shadow-md"
        aria-label={text.hero.primaryCta}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
             aria-hidden="true">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
          <line x1="6" y1="1" x2="6" y2="4"/>
          <line x1="10" y1="1" x2="10" y2="4"/>
          <line x1="14" y1="1" x2="14" y2="4"/>
        </svg>
        {text.hero.primaryCta}
      </a>
      <a href={localizedPath(Astro.url.pathname, '/servicios')}
         class="inline-flex items-center justify-center gap-2 border-2 border-kape-medio/40 text-kape-medio
                font-jakarta font-semibold text-base px-8 py-4 rounded-full
                hover:bg-kape-beige hover:border-kape-medio transition-all duration-300"
         aria-label={text.hero.secondaryCta}>
        {text.hero.secondaryCta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </a>
    </div>

    <!-- Social proof strip -->
    <div class="reveal reveal-delay-4 inline-flex flex-col sm:flex-row items-center gap-4 sm:gap-6
                bg-kape-beige/60 border border-kape-beige rounded-2xl px-6 py-4">
      <div class="flex items-center gap-3">
        <div class="flex -space-x-2">
          {[1,2,3].map(() => (
            <div class="w-8 h-8 rounded-full bg-kape-medio border-2 border-kape-white flex items-center justify-center">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
          ))}
        </div>
          <p class="text-sm text-kape-medio">
          <span class="font-bold text-kape-oscuro">+3</span> {locale === 'en' ? 'businesses already digitized' : 'negocios ya digitalizados'}
        </p>
      </div>
      <div class="hidden sm:block w-px h-6 bg-kape-medio/20"></div>
      <p class="text-sm text-kape-medio">
        <span class="font-bold text-kape-naranja">$0</span> el primer cafecito
      </p>
      <div class="hidden sm:block w-px h-6 bg-kape-medio/20"></div>
      <p class="text-sm text-kape-medio">
        Resultados en <span class="font-bold text-kape-oscuro">semanas, no meses</span>
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="reveal reveal-delay-5 absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <span class="text-xs text-kape-medio uppercase tracking-widest">{text.hero.scroll}</span>
    <div class="w-px h-8 bg-gradient-to-b from-kape-medio to-transparent animate-pulse"></div>
  </div>

  <!-- Bottom wave organic -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg"
         preserveAspectRatio="none" class="w-full h-16 lg:h-20">
      <path d="M0 80 C240 20, 480 60, 720 40 C960 20, 1200 60, 1440 30 L1440 80 Z"
            fill="#F5E9DA"/>
    </svg>
  </div>
</section>

<script is:inline>
// ── Falling coffee beans canvas animation ─────────────
(function() {
  const canvas = document.getElementById('beans-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  function resize() {
    canvas.width  = canvas.offsetWidth  || window.innerWidth;
    canvas.height = canvas.offsetHeight || window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function Bean(initial) {
    this.reset = function(init) {
      this.x            = Math.random() * canvas.width;
      this.y            = init ? Math.random() * canvas.height : -20 - Math.random() * 80;
      this.size         = 5 + Math.random() * 9;
      this.speedY       = 0.5 + Math.random() * 1.1;
      this.rotation     = Math.random() * Math.PI * 2;
      this.rotSpeed     = (Math.random() - 0.5) * 0.025;
      this.opacity      = 0.05 + Math.random() * 0.13;
      this.wobblePhase  = Math.random() * Math.PI * 2;
      this.wobbleSpeed  = 0.007 + Math.random() * 0.014;
      this.wobbleAmp    = 0.4 + Math.random() * 2.2;
    };
    this.reset(initial);

    this.update = function() {
      this.y           += this.speedY;
      this.rotation    += this.rotSpeed;
      this.wobblePhase += this.wobbleSpeed;
      this.x           += Math.sin(this.wobblePhase) * this.wobbleAmp;
      if (this.y > canvas.height + 30) this.reset(false);
    };

    this.draw = function() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rotation);
      ctx.globalAlpha = this.opacity;

      // Bean body
      ctx.beginPath();
      ctx.ellipse(0, 0, this.size * 0.55, this.size, 0, 0, Math.PI * 2);
      ctx.fillStyle = '#6F4E37';
      ctx.fill();

      // Center crease (bezier curve)
      ctx.beginPath();
      ctx.moveTo(0, -this.size * 0.82);
      ctx.bezierCurveTo(
        this.size * 0.18, -this.size * 0.28,
        this.size * 0.18,  this.size * 0.28,
        0,                 this.size * 0.82
      );
      ctx.strokeStyle = '#4B2E2B';
      ctx.lineWidth   = Math.max(1, this.size * 0.1);
      ctx.globalAlpha = this.opacity * 0.55;
      ctx.stroke();

      ctx.restore();
    };
  }

  var beans = [];
  for (var i = 0; i < 32; i++) beans.push(new Bean(true));

  var raf;
  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (var j = 0; j < beans.length; j++) {
      beans[j].update();
      beans[j].draw();
    }
    raf = requestAnimationFrame(animate);
  }
  animate();

  document.addEventListener('visibilitychange', function() {
    if (document.hidden) { cancelAnimationFrame(raf); }
    else { animate(); }
  });
})();
</script>
