---
---
<section id="cafecito" class="py-24 bg-kape-oscuro relative overflow-hidden">

  <!-- Decorative beans (light, subtle) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none select-none">
    <div class="absolute top-8 left-8">
      <div style="width:24px;height:38px;border-radius:50%;background:rgba(245,233,218,0.08);transform:rotate(20deg)"></div>
    </div>
    <div class="absolute top-16 left-20">
      <div style="width:14px;height:22px;border-radius:50%;background:rgba(245,233,218,0.06);transform:rotate(-10deg)"></div>
    </div>
    <div class="absolute bottom-8 right-12 animate-float-3">
      <div style="width:20px;height:32px;border-radius:50%;background:rgba(245,233,218,0.07);transform:rotate(30deg)"></div>
    </div>
    <div class="absolute top-12 right-24 animate-float-1">
      <div style="width:16px;height:26px;border-radius:50%;background:rgba(245,233,218,0.06);transform:rotate(-25deg)"></div>
    </div>
    <!-- Large bg glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full"
         style="background: radial-gradient(ellipse, rgba(111,78,55,0.4) 0%, transparent 70%); filter: blur(60px); top:-100px;"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center relative">

    <!-- Coffee cup icon -->
    <div class="reveal flex justify-center mb-8">
      <div class="w-20 h-20 bg-kape-beige/10 rounded-full flex items-center justify-center
                  ring-2 ring-kape-beige/20 relative">
        <!-- Pulse rings -->
        <div class="absolute inset-0 rounded-full ring-2 ring-kape-naranja/20 animate-pulse-ring"></div>
        <div class="absolute inset-0 rounded-full ring-2 ring-kape-naranja/10 animate-pulse-ring" style="animation-delay:0.5s"></div>
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#F5E9DA" stroke-width="1.5" stroke-linecap="round">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
          <line x1="6" y1="1" x2="6" y2="4"/>
          <line x1="10" y1="1" x2="10" y2="4"/>
          <line x1="14" y1="1" x2="14" y2="4"/>
        </svg>
      </div>
    </div>

    <!-- Headline -->
    <h2 class="reveal reveal-delay-1 font-jakarta font-extrabold text-3xl lg:text-5xl text-kape-white leading-tight mb-6">
      ¿Listo para digitalizar tu negocio?
    </h2>
    <p class="reveal reveal-delay-2 text-kape-beige/70 text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
      Tomemos un cafecito y veamos juntos qué necesitás. Sin compromiso, sin tecnicismos,
      sin presión. Solo una conversación honesta sobre tu negocio y lo que podés lograr.
    </p>

    <!-- CTAs -->
    <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center mb-10">
      <a
        href="https://calendly.com/carlos-kapedigital/cafecito"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ripple inline-flex items-center justify-center gap-3 bg-kape-naranja text-white
               font-jakarta font-bold text-lg px-10 py-4 rounded-full
               hover:bg-orange-500 transition-all duration-300 shadow-lg hover:shadow-kape-glow"
        aria-label="Agendar cafecito exploratorio en Calendly (abre en nueva pestaña)"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
             aria-hidden="true">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
          <line x1="6" y1="1" x2="6" y2="4"/>
          <line x1="10" y1="1" x2="10" y2="4"/>
          <line x1="14" y1="1" x2="14" y2="4"/>
        </svg>
        Agendar cafecito exploratorio (gratis)
      </a>
      <a
        href="mailto:hola@kapedigital.com"
        class="inline-flex items-center justify-center gap-2 border-2 border-kape-beige/30 text-kape-beige
               font-jakarta font-semibold text-base px-8 py-4 rounded-full
               hover:bg-kape-beige/10 transition-all duration-300"
        aria-label="Enviar correo a hola@kapedigital.com"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        hola@kapedigital.com
      </a>
    </div>

    <!-- Quote form -->
    <form id="quote-form" class="reveal reveal-delay-4 max-w-3xl mx-auto bg-kape-white/6 border border-kape-beige/15 rounded-3xl p-6 lg:p-8 text-left">
      <div class="grid md:grid-cols-2 gap-4">
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Nombre</span>
          <input name="name" required type="text" placeholder="Tu nombre"
                 class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro placeholder:text-kape-medio/40 outline-none ring-1 ring-transparent focus:ring-kape-naranja" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Correo</span>
          <input name="email" required type="email" placeholder="tu@correo.com"
                 class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro placeholder:text-kape-medio/40 outline-none ring-1 ring-transparent focus:ring-kape-naranja" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Empresa</span>
          <input name="company" type="text" placeholder="Nombre de tu negocio"
                 class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro placeholder:text-kape-medio/40 outline-none ring-1 ring-transparent focus:ring-kape-naranja" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Servicio</span>
          <select name="service" class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro outline-none ring-1 ring-transparent focus:ring-kape-naranja">
            <option value="">Seleccioná una opción</option>
            <option>Grano</option>
            <option>Tueste</option>
            <option>Pergamino</option>
            <option>Finca</option>
            <option>Catación express</option>
          </select>
        </label>
      </div>

      <div class="mt-4 grid gap-4">
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Presupuesto estimado</span>
          <input name="budget" type="text" placeholder="Ej: $500 - $1,000"
                 class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro placeholder:text-kape-medio/40 outline-none ring-1 ring-transparent focus:ring-kape-naranja" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-kape-beige mb-2">Mensaje</span>
          <textarea name="message" required rows="5" placeholder="Contame qué necesitás, plazos y cualquier detalle útil..."
                    class="w-full rounded-xl bg-kape-white/95 px-4 py-3 text-kape-oscuro placeholder:text-kape-medio/40 outline-none ring-1 ring-transparent focus:ring-kape-naranja"></textarea>
        </label>
      </div>

      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <div class="mt-5 flex flex-col sm:flex-row items-start sm:items-center gap-3">
        <button type="submit" class="btn-ripple inline-flex items-center justify-center gap-2 rounded-full bg-kape-naranja px-6 py-3 font-semibold text-white hover:bg-orange-700 transition-colors">
          Enviar cotización por correo
        </button>
        <p id="quote-form-status" class="text-sm text-kape-beige/70"></p>
      </div>
    </form>

    <!-- Fine print -->
    <p class="reveal reveal-delay-4 text-kape-beige/40 text-sm">
      Sin compromiso · 30 minutos · Gratis · Respondemos en menos de 24h
    </p>
  </div>
</section>

<script is:inline>
  const quoteForm = document.getElementById('quote-form');
  const quoteStatus = document.getElementById('quote-form-status');

  if (quoteForm && quoteStatus) {
    quoteForm.addEventListener('submit', async function(event) {
      event.preventDefault();
      quoteStatus.textContent = 'Enviando...';

      const formData = new FormData(quoteForm);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const payload = await response.json();

        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || 'No se pudo enviar el mensaje.');
        }

        quoteForm.reset();
        quoteStatus.textContent = 'Listo. Te respondemos al correo que dejaste en menos de 24h.';
      } catch (error) {
        quoteStatus.textContent = error instanceof Error ? error.message : 'No se pudo enviar el mensaje.';
      }
    });
  }
</script>
