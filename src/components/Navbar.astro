---
const links = [
  { label: 'Servicios',  href: '/servicios'  },
  { label: 'Portafolio', href: '/portafolio' },
  { label: 'Blog',       href: '/blog'       },
  { label: 'Sobre mí',  href: '/sobre'      },
];
---
<header id="navbar"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 navbar-blur"
  style="background-color: rgba(250,247,242,0.72);">
  <nav class="max-w-6xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group flex-shrink-0" aria-label="Kape Digital — volver a inicio">
      <svg width="30" height="30" viewBox="0 0 32 32" fill="none" aria-hidden="true"
           class="transition-transform duration-300 group-hover:rotate-12">
        <path d="M5 14 L6 26 Q10 30 16 30 Q22 30 26 26 L27 14 Z"
              fill="#F5E9DA" stroke="#6F4E37" stroke-width="1.2"/>
        <ellipse cx="16" cy="14" rx="11" ry="3.5" fill="#4B2E2B"/>
        <ellipse cx="16" cy="14.5" rx="10" ry="2.8" fill="#6F4E37"/>
        <path d="M27 18 Q32 18 32 22 Q32 26 27 26"
              stroke="#6F4E37" stroke-width="1.8" fill="none" stroke-linecap="round"/>
        <path d="M12 11 Q10 7 12 4" stroke="#9B7A65" stroke-width="1.1"
              fill="none" stroke-linecap="round" opacity="0.6" class="animate-steam-1"/>
        <path d="M19 10 Q17 6 19 3" stroke="#9B7A65" stroke-width="1.1"
              fill="none" stroke-linecap="round" opacity="0.6" class="animate-steam-2"/>
      </svg>
      <span class="font-jakarta font-bold text-xl leading-none">
        <span class="text-kape-naranja">K</span><span class="text-kape-oscuro">ape</span>
        <span class="text-kape-medio font-normal italic text-sm ml-0.5">Digital</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-7 flex-1 justify-center">
      {links.map(link => (
        <li>
          <a href={link.href}
             class="text-sm font-medium text-kape-medio hover:text-kape-oscuro transition-colors duration-200 hover-line">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a href="/#cafecito"
       class="hidden lg:inline-flex items-center gap-2 bg-kape-naranja text-white text-sm font-semibold
              px-5 py-2.5 rounded-full btn-ripple hover:bg-orange-700 transition-colors duration-200 flex-shrink-0"
       aria-label="Agendar cafecito exploratorio gratis">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
        <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
        <line x1="6" y1="1" x2="6" y2="4"/>
        <line x1="10" y1="1" x2="10" y2="4"/>
        <line x1="14" y1="1" x2="14" y2="4"/>
      </svg>
      Agendar cafecito
    </a>

    <!-- Hamburger -->
    <button id="menu-btn"
            class="lg:hidden p-2 rounded-lg text-kape-medio hover:bg-kape-beige transition-colors"
            aria-label="Abrir menú de navegación"
            aria-controls="mobile-nav"
            aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-nav"
       class="hidden lg:hidden bg-kape-white/96 navbar-blur border-t border-kape-beige px-6 py-5">
    <ul class="flex flex-col gap-4 mb-5">
      {links.map(link => (
        <li>
          <a href={link.href}
             class="text-kape-medio font-medium text-base hover:text-kape-naranja transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul> hover:bg-orange-700 transition-colors"
       aria-label="Agendar cafecito exploratorio gratis
    <a href="/#cafecito"
       class="flex items-center justify-center gap-2 bg-kape-naranja text-white text-sm font-semibold
              px-5 py-3 rounded-full btn-ripple">
      Agendar cafecito gratis
    </a>
  </div>
</header>
