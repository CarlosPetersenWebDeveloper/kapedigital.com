---
import { getLocale, getSiteText, localizedHome, localizedPath } from '../i18n';

const locale = getLocale(Astro.url.pathname);
const text = getSiteText(locale);

const links = [
  { label: text.nav.services, href: localizedPath(Astro.url.pathname, '/servicios') },
  { label: text.nav.portfolio, href: localizedPath(Astro.url.pathname, '/portafolio') },
  { label: text.nav.blog, href: localizedPath(Astro.url.pathname, '/blog') },
  { label: text.nav.about, href: localizedPath(Astro.url.pathname, '/sobre') },
];

const currentPath = Astro.url.pathname;
const switchHref = locale === 'en'
  ? (currentPath === '/en' || currentPath === '/en/' ? '/' : currentPath.replace(/^\/en/, '') )
  : `/en${currentPath === '/' ? '' : currentPath}`;
---
<header id="navbar"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 navbar-blur"
  style="background-color: rgba(250,247,242,0.72);">
  <nav class="max-w-6xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href={localizedHome(Astro.url.pathname)} class="flex items-center gap-2.5 group flex-shrink-0" aria-label={locale === 'en' ? 'Kape Digital - back to home' : 'Kape Digital — volver a inicio'}>
      <span class="font-jakarta font-bold text-xl leading-none">
        <span class="text-kape-naranja">K</span><span class="text-kape-oscuro">ape</span>
        <span class="text-kape-medio font-normal italic text-sm ml-0.5">Digital</span>
      </span>
    </a>

    <a href={switchHref}
       class="hidden lg:inline-flex items-center justify-center rounded-full border border-kape-medio/20 px-3 py-1.5 text-xs font-semibold text-kape-medio hover:bg-kape-beige transition-colors"
       aria-label={text.nav.languageLabel}>
      {text.nav.language}
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-7 flex-1 justify-center">
      {links.map(link => (
        <li>
          <a href={link.href}
             class="text-sm font-medium text-kape-medio hover:text-kape-oscuro transition-colors duration-200 hover-line">
            {link.label}
          </a>
        </li>
      ))}
    </ul>



    <!-- Hamburger -->
    <button id="menu-btn"
            class="lg:hidden p-2 rounded-lg text-kape-medio hover:bg-kape-beige transition-colors"
          aria-label={locale === 'en' ? 'Open navigation menu' : 'Abrir menú de navegación'}
            aria-controls="mobile-nav"
            aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-nav"
       class="hidden lg:hidden bg-kape-white/96 navbar-blur border-t border-kape-beige px-6 py-5">
    <div class="flex items-center justify-between mb-4">
      <span class="text-xs font-semibold uppercase tracking-wider text-kape-medio/50">{locale === 'en' ? 'Menu' : 'Menú'}</span>
      <a href={switchHref} class="text-xs font-semibold text-kape-naranja" aria-label={text.nav.languageLabel}>{text.nav.language}</a>
    </div>
    <ul class="flex flex-col gap-4">
      {links.map(link => (
        <li>
          <a href={link.href}
             class="text-kape-medio font-medium text-base hover:text-kape-naranja transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
