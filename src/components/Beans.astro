---
const { class: extraClass = '' } = Astro.props;
---
<div class={`beans-decor ${extraClass}`} aria-hidden="true">
  <svg class="bean bean-1" viewBox="0 0 24 24" width="44" height="30" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M12 2c3 0 7 2 7 7s-4 9-7 13c-3-4-7-7.5-7-13s4-7 7-7z" fill="#3a2f29" fill-opacity="0.12"/>
    <path d="M10 6c1.5-1 3.5-1 5 0" stroke="#3a2f29" stroke-opacity="0.22" stroke-width="0.8" stroke-linecap="round"/>
  </svg>

  <svg class="bean bean-2" viewBox="0 0 24 24" width="32" height="22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M12 3c2 0 5 1.5 5 5s-3 7-5 10c-2-3-5-6-5-10s3-5 5-5z" fill="#3a2f29" fill-opacity="0.10"/>
    <path d="M11 7c1-0.7 2-0.7 3 0" stroke="#3a2f29" stroke-opacity="0.2" stroke-width="0.7" stroke-linecap="round"/>
  </svg>

  <svg class="bean bean-3" viewBox="0 0 24 24" width="24" height="16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M12 4c1.5 0 3 1 3 3s-1.5 4-3 6c-1.5-2-3-4-3-6s1.5-3 3-3z" fill="#3a2f29" fill-opacity="0.08"/>
  </svg>
</div>

<style>
.beans-decor { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.beans-decor svg { position: absolute; transform-origin: center; }
.beans-decor .bean-1 { right: 6%; top: 10%; opacity: 0.9; transform: rotate(-12deg) scale(1.0); }
.beans-decor .bean-2 { left: 14%; top: 22%; opacity: 0.8; transform: rotate(8deg) scale(0.95); }
.beans-decor .bean-3 { right: 18%; bottom: 8%; opacity: 0.75; transform: rotate(-6deg) scale(0.85); }

@media (min-width: 1280px) {
  .beans-decor .bean-1 { width: 68px; height: 48px; right: 4%; top: 6%; opacity: 0.95; }
  .beans-decor .bean-2 { width: 52px; height: 36px; left: 10%; top: 18%; }
  .beans-decor .bean-3 { width: 40px; height: 28px; right: 16%; bottom: 6%; }
}

@media (prefers-reduced-motion: no-preference) {
  .beans-decor .bean-1 { animation: drift-1 12s linear infinite; }
  .beans-decor .bean-2 { animation: drift-2 16s linear infinite; }
  .beans-decor .bean-3 { animation: drift-3 10s linear infinite; }
  @keyframes drift-1 { 0% { transform: translateY(0) rotate(-12deg); } 50% { transform: translateY(6px) rotate(-10deg); } 100% { transform: translateY(0) rotate(-12deg); } }
  @keyframes drift-2 { 0% { transform: translateY(0) rotate(8deg); } 50% { transform: translateY(-6px) rotate(10deg); } 100% { transform: translateY(0) rotate(8deg); } }
  @keyframes drift-3 { 0% { transform: translateY(0) rotate(-6deg); } 50% { transform: translateY(4px) rotate(-4deg); } 100% { transform: translateY(0) rotate(-6deg); } }
}
</style>