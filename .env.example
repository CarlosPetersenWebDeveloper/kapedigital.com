# Vercel Environment Variables - Production
# Copia este archivo a .env.local y completa con valores reales

# Email configuration - update with your own Resend credentials
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=no-reply@kapedigital.com
QUOTE_TO_EMAIL=hola@kapedigital.com

# Analytics (Google Analytics 4)
VITE_GA4_ID=

# API endpoints
VITE_API_BASE_URL=https://kapedigital.com

# Feature flags
VITE_ENABLE_CONTACT_FORM=true
